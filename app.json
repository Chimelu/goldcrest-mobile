{
  "expo": {
    "name": "goldcrest-mobile",
    "slug": "goldcrest-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/goldcrest-logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/goldcrest-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#050816"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#050816",
        "foregroundImage": "./assets/images/goldcrest-logo.png"
      }
    },
    "web": {
      "favicon": "./assets/images/goldcrest-logo.png"
    }
  }
}
