# API base URL override (no trailing slash). Restart Expo after changing.
#
# If omitted: dev uses Expo LAN host when possible, else localhost; release uses Vercel URL.
#
# Local examples:
#   iOS Simulator:     EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
#   Android Emulator:  EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
#                      (app rewrites to 10.0.2.2 so it hits your PC)
#   Real phone:        EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:4000
#                      (use your Mac/PC Wi‑Fi IP; phone and PC on same network)
#
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.42:4000
